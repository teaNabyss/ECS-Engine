<?xml version="1.0" encoding="UTF-8"?>
<Assets>

	<Components>

		<!-- Shaders -->
		<Component name="defaultShader" type="ShaderComponent"
            vert="shaders/multiplePhongVert.glsl"
            frag="shaders/multiplePhongFrag.glsl"/>

		<!-- Meshes -->
		<Component name="tileMesh" type="MeshComponent"
            mesh="meshes/CheckerPiece.obj"/>
		
		<Component name="boardMesh" type="MeshComponent"
			mesh="meshes/Plane.obj"/>

		
		<!-- Materials -->
		<Component name="blackMaterial" type="MaterialComponent"
            texture="textures/blackCheckerPiece.png"/>
		
		<Component name="whiteMaterial" type="MaterialComponent"
            texture="textures/whiteCheckerPiece.png"/>
		
		<Component name="boardMaterial" type="MaterialComponent"
            texture="textures/8x8_checkered_board.png"/>

		
		<!-- Transform -->
		<Component name="boardTransform" type="TransformComponent"
			px="0.0" py="-1.65" pz="-5.0"
			ow="0.7071" ox="-0.7071" oy="0" oz="0"
			sx="0.8" sy="0.8" sz="0.8"/>		
	</Components>

	<Actors>

		<!-- Camera -->
		<Actor name="mainCamera" type="CameraActor"
            fovy="45.0" aspect="1.7778" near="0.5" far="100.0"/>
		
		<!-- Board -->
		<Actor name="checkerBoard" type="Actor"
		mesh="boardMesh"
        material="boardMaterial"
        shader="defaultShader"
		transform="boardTransform"/>
		
		<!-- Black pieces -->
		<Actor name="blackPieces" type="CheckerSet"
        startRow="0" endRow="3"
        spacing="1.0"
        mesh="tileMesh"
        material="blackMaterial"
        shader="defaultShader"/>

		<!-- White pieces -->
		<Actor name="whitePieces" type="CheckerSet"
		startRow="5" endRow="8"
		spacing="1.0"
		mesh="tileMesh"
		material="whiteMaterial"
		shader="defaultShader"/>
	</Actors>

</Assets>